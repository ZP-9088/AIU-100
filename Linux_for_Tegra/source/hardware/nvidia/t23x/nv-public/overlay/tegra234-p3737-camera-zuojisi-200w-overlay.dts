						i2c@c250000 {
							z_dser_0: z_max96724 {
								status = "okay";
								compatible = "zuojisi,z_max96724";
								reg = <0x2e>;
								is-master;
							};
							z_ox03c_9295_a {
								status = "okay";
								def-addr = <0x36>; /* actual i2c address of sensor */
								nvidia,gmsl-dser-device = <&z_dser_0>;
								des-link = "A";

								compatible = "zuojisi,z_ox03c_9295";

								reg = <0x14>; /* 9295 will translate to this i2c address */

								devnode = "video0";
								physical_w = "15.0";
								physical_h = "12.5";
								sensor_model ="z_imx219";
								post_crop_frame_drop = "0";
								use_decibel_gain = "true";

								/* enable CID_SENSOR_MODE_ID for sensor modes selection */
								use_sensor_mode_id = "true";

								mode0 {
									mclk_khz = "24000";
									num_lanes = "4";
									tegra_sinterface = "serial_g";
									vc_id = "0";
									phy_mode = "DPHY";
									discontinuous_clk = "no";
									dpcm_enable = "false";
									cil_settletime = "0";
									dynamic_pixel_bit_depth = "10";
									csi_pixel_bit_depth = "10"; 
									mode_type = "bayer";
									pixel_phase = "grbg";

									active_w = "1920";
									active_h = "1080";
									readout_orientation = "0";
									line_length = "1920";
									inherent_gain = "1";
									mclk_multiplier = "24";
									pix_clk_hz = "90000000";
									serdes_pix_clk_hz = "560000000";

									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "1"; /* 1.00x */
									max_gain_val = "170"; /* 10.66x */
									step_gain_val = "1";
									default_gain = "16"; /* 1.00x */
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "30000000"; /* 30.0 fps */
									max_framerate = "30000000"; /* 30.0 fps */
									step_framerate = "1";
									default_framerate = "30000000"; /* 30.0 fps */
									min_exp_time = "13"; /* us */
									max_exp_time = "683709"; /* us */
									step_exp_time = "1";
									default_exp_time = "2495"; /* us */
									embedded_metadata_height = "0";
								};
								ports {
									#address-cells = <1>;
									#size-cells = <0>;
									port@0 {
										reg = <0>;
										z_ox03c_9295_cam_out0: endpoint {
											vc-id = <0>;
											port-index = <6>;
											bus-width = <4>;
											remote-endpoint = <&z_ox03c_9295_csi_in0>;
										};
									};
								};
								gmsl-link {
									num-ser-lanes = <2>;
									streams = "raw10";
								};
							};
							z_ox03c_9295_b {
								status = "okay";
								def-addr = <0x36>; /* actual i2c address of sensor */
								nvidia,gmsl-dser-device = <&z_dser_0>;
								des-link = "B";

								compatible = "zuojisi,z_ox03c_9295";

								reg = <0x15>; /* 9295 will translate to this i2c address */
								devnode = "video1";
								physical_w = "15.0";
								physical_h = "12.5";
								sensor_model ="z_imx219";
								post_crop_frame_drop = "0";
								use_decibel_gain = "true";

								/* enable CID_SENSOR_MODE_ID for sensor modes selection */
								use_sensor_mode_id = "true";

								mode0 {
									mclk_khz = "24000";
									num_lanes = "4";
									tegra_sinterface = "serial_g";
									vc_id = "1";
									phy_mode = "DPHY";
									discontinuous_clk = "no";
									dpcm_enable = "false";
									cil_settletime = "0";
									dynamic_pixel_bit_depth = "10";
									csi_pixel_bit_depth = "10"; 
									mode_type = "bayer";
									pixel_phase = "grbg";

									active_w = "1920";
									active_h = "1080";
									readout_orientation = "0";
									line_length = "1920";
									inherent_gain = "1";
									mclk_multiplier = "24";
									pix_clk_hz = "90000000";
									serdes_pix_clk_hz = "560000000";

									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "1"; /* 1.00x */
									max_gain_val = "170"; /* 10.66x */
									step_gain_val = "1";
									default_gain = "16"; /* 1.00x */
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "30000000"; /* 30.0 fps */
									max_framerate = "30000000"; /* 30.0 fps */
									step_framerate = "1";
									default_framerate = "30000000"; /* 30.0 fps */
									min_exp_time = "13"; /* us */
									max_exp_time = "683709"; /* us */
									step_exp_time = "1";
									default_exp_time = "2495"; /* us */
									embedded_metadata_height = "0";
								};
								ports {
									#address-cells = <1>;
									#size-cells = <0>;
									port@0 {
										reg = <0>;
										z_ox03c_9295_cam_out1: endpoint {
											vc-id = <1>;
											port-index = <6>;
											bus-width = <4>;
											remote-endpoint = <&z_ox03c_9295_csi_in1>;
										};
									};
								};
								gmsl-link {
									num-ser-lanes = <2>;
									streams = "raw10";
								};
							};
							z_ox03c_9295_c {
								status = "okay";
								def-addr = <0x36>; /* actual i2c address of sensor */
								nvidia,gmsl-dser-device = <&z_dser_0>;
								des-link = "C";

								compatible = "zuojisi,z_ox03c_9295";

								reg = <0x16>; /* 9295 will translate to this i2c address */
								devnode = "video2";
								physical_w = "15.0";
								physical_h = "12.5";
								sensor_model ="z_imx219";
								post_crop_frame_drop = "0";
								use_decibel_gain = "true";

								/* enable CID_SENSOR_MODE_ID for sensor modes selection */
								use_sensor_mode_id = "true";

								mode0 {
									mclk_khz = "24000";
									num_lanes = "4";
									tegra_sinterface = "serial_g";
									vc_id = "2";
									phy_mode = "DPHY";
