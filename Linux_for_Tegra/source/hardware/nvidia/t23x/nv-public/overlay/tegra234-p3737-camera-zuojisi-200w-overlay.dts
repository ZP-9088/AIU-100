					module3 {
						status = "okay";
						badge = ISPBADGE;   
						position = "topleft";
						orientation = "1";
						drivernode0 {
							status = "okay";
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/i2c@c250000/z_ox03c_9295_d";
						};
					};
					module4 {
						status = "okay";
						badge = ISPBADGE;   
						position = "bottomright";
						orientation = "1";
						drivernode0 {
							status = "okay";
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/i2c@3180000/z_ox03c_9295_a";
						};
					};
					module5 {
						status = "okay";
						badge = ISPBADGE;   
						position = "topright";
						orientation = "1";
						drivernode0 {
							status = "okay";
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/i2c@3180000/z_ox03c_9295_b";
						};
					};
					module6 {
						status = "okay";
						badge = ISPBADGE;   
