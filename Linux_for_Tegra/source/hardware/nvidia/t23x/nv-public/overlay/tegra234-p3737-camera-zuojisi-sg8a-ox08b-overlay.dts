								};
								port@1 {
									status = "okay";
									reg = <1>;
									z_ox08b_5300_9295_csi_out3: endpoint@7 {
										status = "okay";
										remote-endpoint = <&z_ox08b_5300_9295_vi_in3>;
									};
								};
							};
						};
						channel@4 {
							status = "okay";
							reg = <4>;
							ports {
								status = "okay";
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									status = "okay";
									reg = <0>;
									z_ox08b_5300_9295_csi_in4: endpoint@8 {
										status = "okay";
										port-index = <0>;
										bus-width = <4>;
										remote-endpoint = <&z_ox08b_5300_9295_cam_out4>;
									};
								};
								port@1 {
									status = "okay";
									reg = <1>;
									z_ox08b_5300_9295_csi_out4: endpoint@9 {
										status = "okay";
										remote-endpoint = <&z_ox08b_5300_9295_vi_in4>;
									};
								};
							};
						};
						channel@5 {
							status = "okay";
							reg = <5>;
							ports {
								status = "okay";
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									status = "okay";
									reg = <0>;
									z_ox08b_5300_9295_csi_in5: endpoint@10 {
										status = "okay";
										port-index = <0>;
										bus-width = <4>;
										remote-endpoint = <&z_ox08b_5300_9295_cam_out5>;
									};
								};
								port@1 {
									status = "okay";
									reg = <1>;
									z_ox08b_5300_9295_csi_out5: endpoint@11 {
										status = "okay";
										remote-endpoint = <&z_ox08b_5300_9295_vi_in5>;
									};
								};
							};
						};
						channel@6 {
							status = "okay";
							reg = <6>;
							ports {
								status = "okay";
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									status = "okay";
									reg = <0>;
									z_ox08b_5300_9295_csi_in6: endpoint@12 {
