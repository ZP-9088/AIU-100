							step_gain_val = "300";
							default_gain = "1";
							min_hdr_ratio = "1";
							max_hdr_ratio = "1";
							framerate_factor = "1000000";
							min_framerate = "30000000";
							max_framerate = "30000000";
							step_framerate = "1";
							default_framerate = "30000000";
							exposure_factor = "1000000";
							min_exp_time = "15";
							max_exp_time = "30000";
							step_exp_time = "1";
							default_exp_time = "30000";
							embedded_metadata_height = "0";
						};
						ports {
							#address-cells = <1>;
							#size-cells = <0>;
							port@0 {
								reg = <0>;
								z_ox08b_5300_9295_cam_out1: endpoint {
									vc-id = <1>;
									port-index = <4>;
									bus-width = <4>;
									remote-endpoint = <&z_ox08b_5300_9295_csi_in1>;
								};
							};
						};
						gmsl-link {
							num-ser-lanes = <4>;
							streams = "yuv16";
						};
					};
					z_ox08b_5300_9295_c {
						status = "okay";
						def-addr = <0x6d>;
						nvidia,gmsl-dser-device = <&z_dser_0>;
						des-link = "C";

						compatible = "zuojisi,z_ox08b_5300_9295";
						reg = <0x12>;

						physical_w = "15.0";
						physical_h = "12.5";
						sensor_model = "ox08b40";
						post_crop_frame_drop = "0";
						use_decibel_gain = "true";
						use_sensor_mode_id = "true";

