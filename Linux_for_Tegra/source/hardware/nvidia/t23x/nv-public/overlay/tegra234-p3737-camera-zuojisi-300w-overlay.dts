										remote-endpoint = <&z_imx390_5200_9295_vi_in7>;
									};
								};
							};
						};

					};
				};

				i2c@c250000 {
					z_dser_0: z_max96724 {
						status = "okay";
						compatible = "zuojisi,z_max96724";
						reg = <0x2e>;
					};
					z_imx390_5200_9295_a {
						status = "okay";
						def-addr = <0x50>; /* actual i2c address of imx390 */
						nvidia,gmsl-dser-device = <&z_dser_0>;
						des-link = "A";

						compatible = "zuojisi,z_imx390_5200_9295";
						reg = <0x10>; /* 9295 will translate to this i2c address */

						physical_w = "15.0";
						physical_h = "12.5";
						sensor_model ="imx390";
						post_crop_frame_drop = "0";
						use_decibel_gain = "true";

						/* enable CID_SENSOR_MODE_ID for sensor modes selection */
						use_sensor_mode_id = "true";

						mode0 {
							mclk_khz = "24000";
							num_lanes = "4";
							tegra_sinterface = "serial_g";
							vc_id = "0";
									phy_mode = "DPHY";
							discontinuous_clk = "no";
							dpcm_enable = "false";
							cil_settletime = "0";
							dynamic_pixel_bit_depth = "16";
							csi_pixel_bit_depth = "16"; 
							mode_type = "yuv";
							pixel_phase = "uyvy";

							active_w = "1920";
							active_h = "1536";
							readout_orientation = "0";
							line_length = "2200";
							inherent_gain = "1";
							pix_clk_hz = "165000000";
							serdes_pix_clk_hz = "800000000";

							gain_factor = "10";
							min_gain_val = "0"; /* dB */
							max_gain_val = "420"; /* dB */
							step_gain_val = "3"; /* 0.3 */
							default_gain = "150";
							min_hdr_ratio = "1";
							max_hdr_ratio = "1";
							framerate_factor = "1000000";
							min_framerate = "30000000";
							max_framerate = "30000000";
							step_framerate = "1";
							default_framerate = "30000000";
							exposure_factor = "1000000";
							min_exp_time = "59"; /*us, 2 lines*/
							max_exp_time = "33333";
							step_exp_time = "1";
							default_exp_time = "33333";/* us */
							embedded_metadata_height = "0";
						};
						ports {
							#address-cells = <1>;
							#size-cells = <0>;
							port@0 {
								reg = <0>;
								z_imx390_5200_9295_cam_out0: endpoint {
									vc-id = <0>;
									port-index = <6>;
									bus-width = <4>;
									remote-endpoint = <&z_imx390_5200_9295_csi_in0>;
								};
							};
						};
						gmsl-link {
							num-ser-lanes = <4>;
							streams = "yuv16";
						};
					};
					z_imx390_5200_9295_b {
						status = "okay";
						def-addr = <0x50>; /* actual i2c address of imx390 */
						nvidia,gmsl-dser-device = <&z_dser_0>;
						des-link = "B";
						compatible = "zuojisi,z_imx390_5200_9295";

						reg = <0x11>; /* 9295 will translate to this i2c address */

						physical_w = "15.0";
						physical_h = "12.5";
						sensor_model ="imx390";
						post_crop_frame_drop = "0";
						use_decibel_gain = "true";

						/* enable CID_SENSOR_MODE_ID for sensor modes selection */
						use_sensor_mode_id = "true";

						mode0 {
							mclk_khz = "24000";
							num_lanes = "4";
							tegra_sinterface = "serial_g";
							vc_id = "1";
									phy_mode = "DPHY";
							discontinuous_clk = "no";
							dpcm_enable = "false";
							cil_settletime = "0";
							dynamic_pixel_bit_depth = "16";
							csi_pixel_bit_depth = "16"; 
							mode_type = "yuv";
							pixel_phase = "uyvy";

							active_w = "1920";
							active_h = "1536";
							readout_orientation = "0";
							line_length = "2200";
							inherent_gain = "1";
							pix_clk_hz = "165000000";
							serdes_pix_clk_hz = "800000000";

							gain_factor = "10";
							min_gain_val = "0"; /* dB */
							max_gain_val = "420"; /* dB */
							step_gain_val = "3"; /* 0.3 */
							default_gain = "150";
							min_hdr_ratio = "1";
							max_hdr_ratio = "1";
							framerate_factor = "1000000";
							min_framerate = "30000000";
							max_framerate = "30000000";
							step_framerate = "1";
							default_framerate = "30000000";
							exposure_factor = "1000000";
							min_exp_time = "59"; /*us, 2 lines*/
							max_exp_time = "33333";
							step_exp_time = "1";
							default_exp_time = "33333";/* us */
							embedded_metadata_height = "0";
						};
						ports {
							#address-cells = <1>;
							#size-cells = <0>;
							port@0 {
								reg = <0>;
								z_imx390_5200_9295_cam_out1: endpoint {
									vc-id = <1>;
									port-index = <6>;
									bus-width = <4>;
									remote-endpoint = <&z_imx390_5200_9295_csi_in1>;
								};
							};
						};
						gmsl-link {
							num-ser-lanes = <4>;
							streams = "yuv16";
						};
					};
					z_imx390_5200_9295_c {
						status = "okay";
						def-addr = <0x50>; /* actual i2c address of imx390 */
						nvidia,gmsl-dser-device = <&z_dser_0>;
						des-link = "C";
						compatible = "zuojisi,z_imx390_5200_9295";

						reg = <0x12>; /* 9295 will translate to this i2c address */

						physical_w = "15.0";
						physical_h = "12.5";
						sensor_model ="imx390";
						post_crop_frame_drop = "0";
						use_decibel_gain = "true";

						/* enable CID_SENSOR_MODE_ID for sensor modes selection */
						use_sensor_mode_id = "true";

						mode0 {
							mclk_khz = "24000";
							num_lanes = "4";
							tegra_sinterface = "serial_g";
							vc_id = "2";
									phy_mode = "DPHY";
							discontinuous_clk = "no";
							dpcm_enable = "false";
							cil_settletime = "0";
							dynamic_pixel_bit_depth = "16";
							csi_pixel_bit_depth = "16"; 
							mode_type = "yuv";
							pixel_phase = "uyvy";

							active_w = "1920";
