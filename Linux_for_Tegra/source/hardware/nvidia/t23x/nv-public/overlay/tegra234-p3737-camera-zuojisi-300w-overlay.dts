										status = "okay";
										port-index = <6>;
										bus-width = <4>;
										remote-endpoint = <&z_imx390_5200_9295_cam_out0>;
									};
								};
								port@1 {
									status = "okay";
									reg = <1>;
									z_imx390_5200_9295_csi_out0: endpoint@1 {
										status = "okay";
										remote-endpoint = <&z_imx390_5200_9295_vi_in0>;
									};
								};
							};
						};
						channel@1 {
							status = "okay";
							reg = <1>;
							ports {
								status = "okay";
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									status = "okay";
									reg = <0>;
									z_imx390_5200_9295_csi_in1: endpoint@2 {
										status = "okay";
										port-index = <6>;
										bus-width = <4>;
										remote-endpoint = <&z_imx390_5200_9295_cam_out1>;
									};
								};
								port@1 {
									status = "okay";
									reg = <1>;
									z_imx390_5200_9295_csi_out1: endpoint@3 {
										status = "okay";
										remote-endpoint = <&z_imx390_5200_9295_vi_in1>;
									};
								};
							};
						};
						channel@2 {
							status = "okay";
							reg = <2>;
							ports {
								status = "okay";
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									status = "okay";
									reg = <0>;
									z_imx390_5200_9295_csi_in2: endpoint@4 {
										status = "okay";
										port-index = <6>;
										bus-width = <4>;
										remote-endpoint = <&z_imx390_5200_9295_cam_out2>;
									};
								};
								port@1 {
									status = "okay";
									reg = <1>;
									z_imx390_5200_9295_csi_out2: endpoint@5 {
										status = "okay";
										remote-endpoint = <&z_imx390_5200_9295_vi_in2>;
									};
								};
							};
						};
						channel@3 {
							status = "okay";
