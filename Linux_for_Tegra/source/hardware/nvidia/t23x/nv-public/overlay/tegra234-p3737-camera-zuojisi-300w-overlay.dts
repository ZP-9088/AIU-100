/dts-v1/;
/plugin/;

#define CAM0_RST    TEGRA234_MAIN_GPIO(H, 3)
#define CAM0_PWDN    TEGRA234_MAIN_GPIO(H, 6)
#define CAM1_PWDN    TEGRA234_MAIN_GPIO(AC, 0)
#define CAM_I2C_MUX     TEGRA234_AON_GPIO(CC, 3)

#include <dt-bindings/tegra234-p3767-0000-common.h>

/ {
    overlay-name = "AIU-100 300W Camera";
    jetson-header-name = "Jetson AGX CSI Connector";
    compatible = JETSON_COMPATIBLE;

	fragment@0 {
		target-path = "/";

		__overlay__ {
			zuojisi {
				base {
					label = "xcbase 20250517";
				};
				branch {
					label = "CIG AIU-100 with 300W camera";
				};
			};
			tegra-capture-vi {
				num-channels = <12>;
				ports {
					#address-cells = <1>;
					#size-cells = <0>;
					status = "okay";
					port@0 {
						status = "okay";
						reg = <0>;
						z_imx390_5200_9295_vi_in0: endpoint {
							status = "okay";
							vc-id = <0>;
							port-index = <5>;
							bus-width = <4>;
							remote-endpoint = <&z_imx390_5200_9295_csi_out0>;
						};
					};
					port@1 {
						status = "okay";
						reg = <1>;
						z_imx390_5200_9295_vi_in1: endpoint {
							status = "okay";
							vc-id = <1>;
							port-index = <5>;
							bus-width = <4>;
							remote-endpoint = <&z_imx390_5200_9295_csi_out1>;
						};
					};
					port@2 {
						status = "okay";
						reg = <2>;
						z_imx390_5200_9295_vi_in2: endpoint {
							status = "okay";
							vc-id = <2>;
							port-index = <5>;
							bus-width = <4>;
							remote-endpoint = <&z_imx390_5200_9295_csi_out2>;
						};
					};
					port@3 {
						status = "okay";
						reg = <3>;
						z_imx390_5200_9295_vi_in3: endpoint {
							status = "okay";
							vc-id = <3>;
							port-index = <5>;
							bus-width = <4>;
							remote-endpoint = <&z_imx390_5200_9295_csi_out3>;
						};
					};

					port@4 {
						status = "okay";
						reg = <4>;
						z_imx390_5200_9295_vi_in4: endpoint {
							status = "okay";
							vc-id = <0>;
							port-index = <2>;
							bus-width = <4>;
							remote-endpoint = <&z_imx390_5200_9295_csi_out4>;
						};
					};
					port@5 {
						status = "okay";
						reg = <5>;
						z_imx390_5200_9295_vi_in5: endpoint {
							status = "okay";
							vc-id = <1>;
							port-index = <2>;
							bus-width = <4>;
							remote-endpoint = <&z_imx390_5200_9295_csi_out5>;
						};
					};
					port@6 {
						status = "okay";
						reg = <6>;
						z_imx390_5200_9295_vi_in6: endpoint {
							status = "okay";
							vc-id = <2>;
							port-index = <2>;
							bus-width = <4>;
							remote-endpoint = <&z_imx390_5200_9295_csi_out6>;
						};
					};
					port@7 {
						status = "okay";
						reg = <7>;
						z_imx390_5200_9295_vi_in7: endpoint {
							status = "okay";
							vc-id = <3>;
							port-index = <2>;
							bus-width = <4>;
							remote-endpoint = <&z_imx390_5200_9295_csi_out7>;
						};
					};

				};
			};
			tegra-camera-platform {
				compatible = "nvidia, tegra-camera-platform";
				num_csi_lanes = <16>;
				max_lane_speed = <1500000>;
				min_bits_per_pixel = <10>;
				vi_peak_byte_per_pixel = <2>;
				vi_bw_margin_pct = <25>;
				max_pixel_rate = <7500000>;
				isp_peak_byte_per_pixel = <5>;
				isp_bw_margin_pct = <25>;
			};
			bus@0{
				host1x@13e00000 {
					nvcsi@15a00000 {
						num-channels = <8>;
						#address-cells = <1>;
						#size-cells = <0>;
						channel@0 {
							status = "okay";
							reg = <0>;
							ports {
								status = "okay";
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									status = "okay";
									reg = <0>;
