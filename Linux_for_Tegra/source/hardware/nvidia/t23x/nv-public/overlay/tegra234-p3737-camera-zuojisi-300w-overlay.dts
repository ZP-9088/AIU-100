							min_gain_val = "0"; /* dB */
							max_gain_val = "420"; /* dB */
							step_gain_val = "3"; /* 0.3 */
							default_gain = "150";
							min_hdr_ratio = "1";
							max_hdr_ratio = "1";
							framerate_factor = "1000000";
							min_framerate = "30000000";
							max_framerate = "30000000";
							step_framerate = "1";
							default_framerate = "30000000";
